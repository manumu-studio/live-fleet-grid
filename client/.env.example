# .env.example - copy to .env.local for local overrides, or set VITE_WS_URL in
# your deploy provider (Vercel) for production.
#
# The WebSocket URL the client connects to. In production this is the wss:// form
# of the deployed Go server with the /ws path. When unset, the client falls back
# to ws://localhost:8080/ws for local development.
VITE_WS_URL=wss://<your-go-server-host>/ws
